# =============================================================================
# ROVER CONSULTANCY SERVICES — .htaccess
# SRS Reference: Section 14 (Security Plan) & Section 15 (Performance Strategy)
# For Apache-based cPanel hosting.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. FORCE HTTPS (enable once SSL is active on the live domain — see INSTALL.md)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Uncomment these two lines after SSL certificate is installed:
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www -> www (or comment out if you prefer non-www canonical)
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [L,R=301]

  # Redirect legacy page-file URLs to canonical folder URLs.
  RewriteRule ^about-us/(about-us|index)\.html$ /about-us/ [L,R=301,NC]
  RewriteRule ^air-tickets/(air-tickets|index)\.html$ /air-tickets/ [L,R=301,NC]
  RewriteRule ^blog/(blog|index)\.html$ /blog/ [L,R=301,NC]
  RewriteRule ^contact-us/(contact-us|index)\.html$ /contact-us/ [L,R=301,NC]
  RewriteRule ^hajj/(hajj|index)\.html$ /hajj/ [L,R=301,NC]
  RewriteRule ^hotel-booking/(hotel-booking|index)\.html$ /hotel-booking/ [L,R=301,NC]
  RewriteRule ^privacy-policy/(privacy-policy|index)\.html$ /privacy-policy/ [L,R=301,NC]
  RewriteRule ^terms-of-service/(terms-of-service|index)\.html$ /terms-of-service/ [L,R=301,NC]
  RewriteRule ^tour-packages/(tour-packages|index)\.html$ /tour-packages/ [L,R=301,NC]
  RewriteRule ^umrah/(umrah|index)\.html$ /umrah/ [L,R=301,NC]
  RewriteRule ^visa-services/(visa-services|index)\.html$ /visa-services/ [L,R=301,NC]
</IfModule>

# -----------------------------------------------------------------------------
# 2. SECURITY HEADERS
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — enable only after confirming SSL works site-wide
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# -----------------------------------------------------------------------------
# 3. PREVENT DIRECTORY BROWSING
# -----------------------------------------------------------------------------
Options -Indexes

# -----------------------------------------------------------------------------
# 4. BLOCK ACCESS TO SENSITIVE FILES
# -----------------------------------------------------------------------------
<FilesMatch "\.(md|json|log|env)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Allow the specific frontend data JSON files used by the site
<FilesMatch "^(countries|testimonials|services|faq|settings)\.json$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
  </IfModule>
</FilesMatch>

# -----------------------------------------------------------------------------
# 5. GZIP COMPRESSION
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

# -----------------------------------------------------------------------------
# 6. BROWSER CACHING
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — no long cache since content updates via Google Sheets
  ExpiresByType text/html "access plus 0 seconds"

  # CSS / JS — 1 month (bump cache-busting via filename/version if updated sooner)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Images — 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # JSON data — short cache since content changes when admin updates
  ExpiresByType application/json "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|woff|jpg|jpeg|png|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>

# -----------------------------------------------------------------------------
# 7. CUSTOM ERROR PAGES (add these pages in a future phase if desired)
# -----------------------------------------------------------------------------
# ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# 8. DEFAULT CHARACTER SET
# -----------------------------------------------------------------------------
AddDefaultCharset UTF-8

# -----------------------------------------------------------------------------
# 9. DISABLE SERVER SIGNATURE
# -----------------------------------------------------------------------------
ServerSignature Off
